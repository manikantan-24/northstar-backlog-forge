.env
venv/
__pycache__/
*.pyc
.pytest_cache/
outputs/*.json
outputs/*.md
!outputs/.gitkeep
.DS_Store
.vscode/
.idea/

# local embedding/vector cache
.cache/

# Word lock files
~$*

# Terraform — state files contain secrets, never commit
infra/terraform/.terraform/
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.backup
infra/terraform/terraform.tfstate.*.backup
infra/terraform/.terraform.lock.hcl
# terraform.tfvars contains real API keys — use terraform.tfvars.example as template
infra/terraform/terraform.tfvars
infra/terraform/tfplan

# SQLite audit log chain (runtime artifact, not source)
logs/audit_chain.db

# Agent/IDE local configuration
.claude/
logs/.ui_state.json

# Local runs, test results, and outputs subdirectories
logs/runs/
outputs/*/
test_results/

# Local authentications config
config/auth.yaml

# Architectural references and technical guides
TECHNICAL_GUIDE.md
target_architecture_comparison.md
