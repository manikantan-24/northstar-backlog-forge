# Copy this file to .env and fill in your key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model. Default is claude-sonnet-4-5.
# For multi-agent workloads, Sonnet is the default — agents benefit from the
# stronger reasoning when decomposing epics or judging conflicts. Switch to
# claude-haiku-4-5 only for high-volume / cost-sensitive runs.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: log verbosity. One of DEBUG | INFO | WARNING | ERROR.
# LOG_LEVEL=INFO

# Optional: cap how many retry attempts each agent makes on transient errors.
# AGENT_MAX_RETRIES=3
