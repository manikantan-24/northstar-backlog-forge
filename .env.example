# Copy this file to .env and fill in your key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model. Default is claude-sonnet-4-5.
# For multi-agent workloads, Sonnet is the default — agents benefit from the
# stronger reasoning when decomposing epics or judging conflicts. Switch to
# claude-haiku-4-5 only for high-volume / cost-sensitive runs.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: log verbosity. One of DEBUG | INFO | WARNING | ERROR.
# LOG_LEVEL=INFO

# Optional: cap how many retry attempts each agent makes on transient errors.
# AGENT_MAX_RETRIES=3

# Optional — for Gemini provider (free tier: aistudio.google.com)
# Required when any sidebar "Models" preset points at a gemini-* model
# (Free or Balanced presets do; Premium is all-Claude and doesn't need this).
GOOGLE_API_KEY=

# --- Live Atlassian integration (Jira + Confluence) ---
# Same Atlassian tenant uses one API token for both products. The app
# auto-promotes JIRA_* into CONFLUENCE_* at startup, so you usually only
# need to fill the JIRA_* block above. Override here only if Confluence
# lives on a different tenant.
# CONFLUENCE_BASE_URL=https://your-tenant.atlassian.net
# CONFLUENCE_EMAIL=you@example.com
# CONFLUENCE_API_TOKEN=

# Pre-fill the Confluence page id used by the Streamlit "Live Confluence"
# toggle (the field defaults to this value).
# CONFLUENCE_PAGE_ID=65830

# Force live or mock mode explicitly (default: mock unless you pass
# `mode="live"` in code or use --confluence-page-id / --live-jira on the CLI).
# CONFLUENCE_MODE=mock
# JIRA_MODE=mock

# --- Persistent memory (optional) ---
# When set to 1, MemoryStore writes KV state and embedding vectors to
# `.cache/memory/` so repeated runs on the same backlog skip the embedding
# step. No effect on output, just faster subsequent runs.
# MEMORY_PERSISTENT=0
