# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real secrets.
# Values below match the structure from .env

# ── Infrastructure ─────────────────────────────────────────────────────────
location             = "eastus"
environment          = "staging"
resource_group_name  = "rg-backlog-synthesizer"
acr_name             = "backlogsynth"
keyvault_name        = "kv-backlog-synth"
storage_account_name = "stbacklogsynth"

# ── Non-secret configuration (from .env) ───────────────────────────────────
jira_base_url        = "https://mani-rdedemo.atlassian.net"
jira_email           = "mani_kantan@live.com"
jira_project_key     = "NS"
github_owner         = "manikantan-24"
github_repo          = "northstar-retail-backlog"
entra_tenant_id      = "c9d7f542-549c-4f1e-915f-2c563e40e14b"
entra_client_id      = "18056440-d6ce-46b3-9261-52167231606d"
entra_tenant_domain  = "northstarretailcorp.onmicrosoft.com"
otel_endpoint        = "https://otlp-gateway-prod-ap-south-1.grafana.net/otlp"

# ── Secrets → stored in Key Vault, never in Terraform state as plaintext ───
# Paste real values here when running terraform apply locally.
# These get written to Azure Key Vault and never appear in logs or state.

anthropic_api_key    = "sk-ant-..."           # from ANTHROPIC_API_KEY in .env
google_api_key       = "AIza..."              # from GOOGLE_API_KEY in .env
jira_api_token       = "ATATT3x..."           # from JIRA_API_TOKEN in .env
github_token         = "ghp_..."              # from GITHUB_TOKEN in .env
entra_client_secret  = "QWC8Q~..."            # from ENTRA_CLIENT_SECRET in .env
otel_headers         = "Authorization=Basic MTY3..."  # from OTEL_EXPORTER_OTLP_HEADERS in .env
auth_cookie_secret   = "..."                  # from AUTH_COOKIE_SECRET in .env
slack_webhook_url    = "https://hooks.slack.com/services/..."  # from SLACK_WEBHOOK_URL in .env
